# Ten sam plik dla dev, Docker i K8s (./scripts/deploy-k8s.sh nadpisuje w klastrze:
# QDRANT_HOST, SQLITE_PATH, UPLOAD_DIR).
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
# GPT-4o-mini cena: $0.15/$0.60
VLM_MODEL_NAME=openai/gpt-4o-mini
# DeepSeek V4 Flash cena: $0.10/$0.20
LLM_MODEL_NAME=deepseek/deepseek-v4-flash
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=documents_index
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Lokalnie (dev): ./data/... — w kontenerze Docker/K8s: /app/data/...
SQLITE_PATH=./data/app.db
UPLOAD_DIR=./data/uploads
CHUNK_MAX_TOKENS=400
RAG_DEFAULT_TOP_K=6